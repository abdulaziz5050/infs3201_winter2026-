<style>
    .morning {
        background-color: yellow;
    }
</style>

<h1>Employee Details</h1>

<div>
    {{#if employee.photo}}
    <img src="/images/{{employee.photo}}" alt="{{employee.name}}"
        style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; border: 3px solid #ccc;">
    {{/if}}
    <p><strong>Database ID:</strong> {{employee.id}}</p>
    <p><strong>Name:</strong> {{employee.name}}</p>
    <p><strong>Phone:</strong> {{employee.phone}}</p>
    <a href="/employee/{{employee.id}}/edit">Edit Employee</a>
</div>

<hr>

<h2>Assigned Shifts</h2>
{{#if shifts.length}}
<table border="1">
    <thead>
        <tr>
            <th>Date</th>
            <th>Start Time</th>
            <th>End Time</th>
        </tr>
    </thead>
    <tbody>
        {{#each shifts}}
        <tr class="{{#if isMorning}}morning{{/if}}">
            <td>{{date}}</td>
            <td>{{startTime}}</td>
            <td>{{endTime}}</td>
        </tr>
        {{/each}}
    </tbody>
</table>
{{else}}
<p>No shifts assigned to this employee.</p>
{{/if}}

